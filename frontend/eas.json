{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://whitewater-guide.preview.emergentagent.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://whitewater-guide.preview.emergentagent.com"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://whitewater-guide.preview.emergentagent.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
